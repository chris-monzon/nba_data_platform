# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real credentials or project IDs you want kept private.

# --- GCP ---
GCP_PROJECT_ID=
GCS_BUCKET=
BIGQUERY_DATASET=

# Path to a GCP service-account key JSON (also gitignored).
# For local development, prefer `gcloud auth application-default login` instead of a key file.
GOOGLE_APPLICATION_CREDENTIALS=
