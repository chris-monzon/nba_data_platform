# --- Secrets / credentials (NEVER commit) ---
.env
*.env
!.env.example
secrets/
*-sa.json
service-account*.json
gcp-key*.json
*-credentials.json

# --- Local class materials (not part of the project) ---
course_materials/

# --- Data: never commit raw or derived data (see data/README.md to obtain it) ---
data/*
!data/README.md
*.json
*.parquet
*.7z
*.zip
*.duckdb

# --- Python / uv ---
.venv/
venv/
__pycache__/
*.py[cod]
.uv/

# --- Notebooks ---
.ipynb_checkpoints/

# --- Terraform / infra ---
# Safe .tf config is committed; infra/.gitignore is deny-by-default and decides
# exactly what ships. These repo-wide rules are belt-and-suspenders so state,
# plans, vars, locks, and provider binaries can never be committed from ANY path:
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!*.tfvars.example
*.tfplan
.terraform/
.terraform.tfstate.lock.info
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
